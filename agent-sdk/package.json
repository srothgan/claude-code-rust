    "test": "pnpm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.63"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "typescript": "5.9.3"
  }
}
