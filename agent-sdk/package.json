{
  "name": "@srothgan/claude-rs-agent-bridge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "NDJSON bridge between claude-code-rust and the Claude Agent SDK",
  "main": "dist/bridge.js",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "tsc -p tsconfig.json",
